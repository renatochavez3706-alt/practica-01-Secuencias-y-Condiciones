#include <iostream>
using namespace std;

int main() {
    int n;

    cout << "Ingrese n: ";
    cin >> n;

    long long f0 = 1, f1 = 1, fn;

    if (n == 0 || n == 1) {
        cout << "Fibonacci: 1" << endl;
    } else {
        for (int i = 2; i <= n; i++) {
            fn = f0 + f1;
            f0 = f1;
            f1 = fn;
        }
        cout << "Fibonacci: " << fn << endl;
    }

    return 0;
}
