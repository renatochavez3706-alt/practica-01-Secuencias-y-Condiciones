#include<iostream>
using namespace std;
int main(){
    int num, digito;
    int invertido = 0;
    do{
        cout << "Ingrese un numero: ";
        cin >> num;
    }while(num <= 0);
    while(num > 0){
        digito = num % 10;
        invertido = invertido * 10 + digito;
        num = num / 10;
    }
    cout << "Numero invertido: " << invertido << endl;
    return 0;
}
