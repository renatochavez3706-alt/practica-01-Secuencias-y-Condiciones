#include <iostream>
#include <cmath>
using namespace std;
int main() {
    int n;
    double x, suma = 0;
    cout << "Ingrese x: ";
    cin >> x;
    cout << "Ingrese n: ";
    cin >> n;
    for (int i = 1; i <= n; i++) {
        suma = suma + pow(x, i);
    }
    cout << "La suma es: " << suma << endl;
    return 0;
}
