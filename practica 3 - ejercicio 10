#include <iostream>
#include <cmath>
using namespace std;
int main() {
    int n;
    double x, suma = 0;
    cout << "Ingrese x: ";
    cin >> x;
    cout << "Ingrese n (impar): ";
    cin >> n;
    int signo = 1;
    for (int i = 1; i <= n; i += 2) {
        long long factorial = 1;
        for (int j = 1; j <= i; j++) {
            factorial *= j;
        }
        suma += signo * (pow(x, i) / factorial);
        signo *= -1;  
    }
    cout << "La suma es: " << suma << endl;
    return 0;
}
