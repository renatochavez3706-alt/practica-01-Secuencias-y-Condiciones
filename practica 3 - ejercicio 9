#include <iostream>
#include <cmath>
using namespace std;
int main() {
    int n;
    double x, suma = 0;
    cout << "Ingrese x: ";
    cin >> x;
    cout << "Ingrese n: ";
    cin >> n;
    long long factorial = 1;
    for (int i = 1; i <= n; i++) {
        factorial *= i;
        if (i % 2 == 0) {
            suma -= pow(x, i) / factorial;  
        } else {
            suma += pow(x, i) / factorial;  
    }
    cout << "La suma es: " << suma << endl;
    return 0;
}
