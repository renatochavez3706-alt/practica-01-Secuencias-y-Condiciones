#include <iostream>
using namespace std;
int main() {
    int N;
    long long factorial = 1;
    cout << "Ingrese N: ";
    cin >> N;
    if (N == 0) {
        factorial = 1;
    } else {
        for (int i = 1; i <= N; i++) {
            factorial = factorial * i;
        }
    }
    cout << "El factorial es: " << factorial << endl;
    return 0;
}
