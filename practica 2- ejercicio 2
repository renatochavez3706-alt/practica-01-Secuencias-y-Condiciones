#include <stdio.h>
#include<math.h>
#define PI 3.1416
int main(){
    float R, H, V, Area_lateral, Area_total, volumen;
    
    printf("ingrese el radio:\n");
    scanf("%f",&R);
    
    printf("ingrese la altura:\n");
    scanf("%f",&H);
    
    Area_lateral=2*PI*R*H;
